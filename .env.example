# Chi tiet production + TikTok/Shopee/Facebook: docs/env-production.md
# Affiliate / dang cheo kenh: docs/affiliate-crosspost.md
# REDIS_URL=redis://localhost:6379  # optional — health + hang doi job
# USE_JOB_QUEUE=1                  # API day job id vao Redis; worker BRPOP + claim DB
# JOB_QUEUE_RENDER_KEY=appaffilate:queue:render
# JOB_QUEUE_PUBLISH_KEY=appaffilate:queue:publish
# JOB_QUEUE_BRPOP_SEC=3
# METRICS_TOKEN=                   # neu dat thi GET /metrics?token=...
# ALERT_WEBHOOK_URL=               # worker POST JSON khi co notification escalation (fail job)
# COST_RENDER_UNIT_USD=0.03
# COST_PUBLISH_UNIT_USD=0.02
DATABASE_URL=postgres://appaffilate:appaffilate@localhost:5432/appaffilate
AUTH_SECRET=dev-auth-secret
PORT=4000
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
OBJECT_STORAGE_DRIVER=local
OBJECT_STORAGE_LOCAL_DIR=./apps/api/object-storage
OBJECT_STORAGE_BUCKET=appaffilate-assets
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_FORCE_PATH_STYLE=true
TIKTOK_OAUTH_AUTHORIZE_URL=
TIKTOK_OAUTH_TOKEN_URL=
TIKTOK_PUBLISH_URL=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
SHOPEE_OAUTH_AUTHORIZE_URL=
SHOPEE_OAUTH_TOKEN_URL=
SHOPEE_PUBLISH_URL=
SHOPEE_CLIENT_ID=
SHOPEE_CLIENT_SECRET=
