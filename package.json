{
  "name": "appaffilate",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "dev:web": "npm --workspace @appaffilate/web run dev",
    "dev:api": "npm --workspace @appaffilate/api run dev",
    "dev:worker": "npm --workspace @appaffilate/worker run dev",
    "dev:all": "concurrently -k -n api,worker,web \"npm run dev:api\" \"npm run dev:worker\" \"npm run dev:web\"",
    "start:all": "npm run infra:up && npm run dev:all",
    "db:reset-demo": "npm --workspace @appaffilate/api run db:reset-demo",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
